# Local development:
# Browser requests go to /api and Vite proxies them to VITE_PROXY_TARGET.
VITE_API_BASE_URL=/api
VITE_API_PREFIX=
VITE_PROXY_TARGET=http://127.0.0.1:8000

# Production options:
# 1) Recommended behind Nginx reverse proxy:
#    VITE_API_BASE_URL=/api
# 2) Direct backend access if needed:
#    VITE_API_BASE_URL=http://124.223.14.145:8000
